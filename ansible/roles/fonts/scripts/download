NERD_FONT_ASSET_ALIASES = {
    # Nerd Fonts v3.4.0 no longer publishes a standalone FontAwesome archive.
    # The symbols now ship via the SymbolsOnly bundle instead.
    'FontAwesome': 'NerdFontsSymbolsOnly',
}

def download_to_file(url, out_path):
    response = requests.get(url, allow_redirects=True, stream=True)
    response.raise_for_status()
    with open(out_path, "wb") as f:
        for chunk in response.iter_content(chunk_size=1024 * 64):
            if chunk:
                f.write(chunk)
    return out_path


def nerd_release_asset_name(family):
    return NERD_FONT_ASSET_ALIASES.get(family, family)


def nerd_download_family(family, font_dir):
    base_url = 'https://github.com/ryanoasis/nerd-fonts/releases/latest'
    response = requests.get(base_url)
    latest_version = response.url.rsplit('/', 1)[-1]
    asset_name = nerd_release_asset_name(family)
    download_url = f"https://github.com/ryanoasis/nerd-fonts/releases/download/{latest_version}/{asset_name}.zip"
    archive_path = f"/tmp/{asset_name}.zip"
    download_to_file(download_url, archive_path)
    print(archive_path)
    zip_file = zipfile.ZipFile(archive_path, "r")
    [zip_file.extract(file, font_dir) for file in zip_file.namelist() if file.endswith(('.ttf', '.otf'))]
    zip_file.close()
    
styles = {
    100: 'Thin',
    200: 'ExtraLight',
    300: 'Light',
    400: 'Regular',
    500: 'Medium',
    600: 'SemiBold',
    700: 'Bold',
    800: 'ExtraBold',
    900: 'Black',
}

# Named instances of the "Recursive" variable font (MONO/CASL axes), keyed by
# the word used to request them. Google's css2 API only recognizes the base
# "Recursive" family -- "Recursive Mono Casual" et al. are axis positions
# within it, not family names it accepts via `family=`, so translate the
# words after "Recursive" into pinned axis values instead.
RECURSIVE_AXIS_TOKENS = {
    'sans': ('MONO', '0'),
    'mono': ('MONO', '1'),
    'linear': ('CASL', '0'),
    'casual': ('CASL', '1'),
}

def recursive_axis_pins(family):
    """Return {'MONO': ..., 'CASL': ...} for a compound 'Recursive ...' name, else None."""
    words = family.split()
    if len(words) < 2 or words[0] != 'Recursive':
        return None
    axes = {'MONO': '0', 'CASL': '0'}
    for word in words[1:]:
        axis, value = RECURSIVE_AXIS_TOKENS.get(word.lower(), (None, None))
        if axis is None:
            return None
        axes[axis] = value
    return axes

def rename_font_family(path, family, style):
    """Rewrite PATH's name table so fontconfig sees FAMILY/STYLE.

    Needed for Recursive named instances: the file downloaded from Google
    is internally named after Google's own instance (e.g. "Recursive
    Monospace Casual"), which doesn't match the family name we requested
    (e.g. "Recursive Mono Casual"), so it wouldn't be found under that name.
    """
    from fontTools.ttLib import TTFont
    font = TTFont(path)
    name_table = font['name']
    full_name = family if style == 'Regular' else f'{family} {style}'
    replacements = {1: family, 2: style, 4: full_name, 6: full_name.replace(' ', ''), 16: family, 17: style}
    for record in list(name_table.names):
        if record.nameID in replacements:
            name_table.setName(replacements[record.nameID], record.nameID,
                                record.platformID, record.platEncID, record.langID)
    font.save(path)

def google_download_variant(family, weight, variant, url, font_dir, rename_to=None):
    print(f"Downloading {family}-{variant} [weight: {weight}] from {url}")
    path = urlparse(url).path
    ext = splitext(path)[1]
    out_path = os.path.join(font_dir, f"{family}-{variant}{ext}")
    download_to_file(url, out_path)
    print(out_path)
    if rename_to:
        rename_font_family(out_path, rename_to, variant)

def google_download_family(family, font_dir):
    base_url = 'https://fonts.googleapis.com/css2'
    weight_values = (100, 200, 300, 400, 500, 600, 700, 800, 900)
    axes = recursive_axis_pins(family)
    if axes:
        axis_tags = ','.join(list(axes.keys()) + ['wght'])
        pins = ';'.join(f"{axes['MONO']},{axes['CASL']},{w}" for w in weight_values)
        url = f'{base_url}?family=Recursive:{axis_tags}@{pins}&display=swap'
    else:
        weights = ';'.join(str(w) for w in weight_values)
        url = f'{base_url}?family={family}:wght@{weights}&display=swap'
    r = requests.get(url, allow_redirects=True)

    weight_re = re.compile(r"^\s*font-weight:\s*(?P<weight>[0-9]+);.*$")
    url_re = re.compile(r"^\s*src: url\((?P<url>[^)]+)\).*$")

    variant_weight = None
    variant_url = None
    for l in r.content.decode().split('\n'):
        m = weight_re.match(l)
        if m:
            variant_weight = m.group('weight')
        m = url_re.match(l)
        if m:
            variant_url = m.group('url')

        if variant_weight and variant_url:
            google_download_variant(family, variant_weight, styles[int(variant_weight)], variant_url, font_dir,
                                     rename_to=family if axes else None)
            variant_weight = None
            variant_url = None

def main(family_and_source, base_dir):
    family, source = family_and_source.split(':')

    font_dir = os.path.join(base_dir, source, family)
    Path(font_dir).mkdir(parents=True, exist_ok=True)

    if source == 'google':
        google_download_family(family, font_dir)
    elif source == 'nerd':
        nerd_download_family(family, font_dir)
    else:
        print("Unknown source")
    
#    css=cssutils.parseUrl(url)
#    print(css.cssText)
    
if __name__ == '__main__':
    parser = argparse.ArgumentParser(
        prog='google-download',
        description='Download a single family of Google fonts',
    )
    parser.add_argument('family')
    parser.add_argument('base_dir')
    args = parser.parse_args()

    print(f'DIR: {args.base_dir}')
    main(family_and_source=args.family, base_dir=args.base_dir)
